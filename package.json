{
  "name": "youtube-music-mcp",
  "version": "0.1.0",
  "description": "MCP server for managing YouTube Music playlists via Claude",
  "main": "dist/main.js",
  "bin": {
    "youtube-music-mcp": "./bin/run.js"
  },
  "scripts": {
    "build": "tsc && cp src/cache/schema.sql dist/cache/schema.sql",
    "dev": "tsx src/main.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "mcp",
    "youtube-music",
    "playlist",
    "claude",
    "ai"
  ],
  "author": "Dustin Barnes",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.6.1",
    "better-sqlite3": "^11.10.0",
    "googleapis": "^144.0.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^3.0.0"
  }
}
